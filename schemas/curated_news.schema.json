{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "curated_news.schema.json",
  "title": "CuratedNews",
  "type": "object",
  "required": ["curated_at", "items"],
  "properties": {
    "curated_at": { "type": "string", "format": "date-time" },
    "items": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["rank", "title", "sources", "summary", "relevance_reason"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "url": { "type": "string", "format": "uri" }
              }
            }
          },
          "summary": { "type": "string" },
          "relevance_reason": { "type": "string" }
        }
      }
    }
  }
}
